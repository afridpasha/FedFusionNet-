# NeuroPlex Environment Variables
# Copy this file to .env and fill in your API keys

# ============================================
# VISION-LANGUAGE MODEL API KEYS (FREE)
# ============================================

# Google Gemini 2.5 Flash API Key (Primary VLM)
# Get your FREE API key from: https://makersuite.google.com/app/apikey
# Rate Limit: 1500 requests/day FREE
GEMINI_API_KEY=your_gemini_api_key_here

# Groq Llama 3.3 70B API Key (Fallback VLM)
# Get your FREE API key from: https://console.groq.com/
# Rate Limit: Unlimited FREE
GROQ_API_KEY=your_groq_api_key_here

# ============================================
# FLASK CONFIGURATION
# ============================================

# Flask environment (development/production)
FLASK_ENV=production

# Flask secret key (generate a random string)
FLASK_SECRET_KEY=your_secret_key_here_change_this_in_production

# Flask debug mode (True/False)
FLASK_DEBUG=False

# ============================================
# DATABASE CONFIGURATION (OPTIONAL)
# ============================================

# MongoDB connection string (optional, for production)
# If not provided, application will work without database
# MONGODB_URI=mongodb://localhost:27017/neuroplex

# ============================================
# APPLICATION SETTINGS
# ============================================

# Maximum file upload size (in MB)
MAX_UPLOAD_SIZE=10

# Session timeout (in minutes)
SESSION_TIMEOUT=60

# Enable/disable features
ENABLE_VLM=True
ENABLE_SHAP=True
ENABLE_SURVIVAL_ANALYSIS=True
ENABLE_WSI=True
ENABLE_TEMPORAL_COMPARISON=True

# ============================================
# MODEL PATHS
# ============================================

# Path to CNN model file
CNN_MODEL_PATH=backend/models/hetfusionnet_v2_FINAL.pth

# Path to tabular model file
TABULAR_MODEL_PATH=backend/models/stage2_tabular_model.pkl

# ============================================
# LOGGING
# ============================================

# Log level (DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/app.log

# ============================================
# CLOUDFLARE R2 STORAGE (FOR PDF REPORTS)
# ============================================

# Cloudflare R2 Access Key ID
# Get from: Cloudflare Dashboard > R2 > Manage R2 API Tokens
R2_ACCESS_KEY_ID=your_r2_access_key_id_here

# Cloudflare R2 Secret Access Key
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here

# Cloudflare R2 Endpoint URL
# Format: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com

# R2 Bucket Name
R2_BUCKET_NAME=neuroplex-reports

# R2 Public URL (optional, if bucket has public access enabled)
# Format: https://pub-<id>.r2.dev/neuroplex-reports
# R2_PUBLIC_URL=https://pub-xxx.r2.dev/neuroplex-reports

# ============================================
# HUGGING FACE SPACES SPECIFIC
# ============================================

# Port for Hugging Face Spaces (default: 7860)
PORT=7860

# Host (default: 0.0.0.0 for Hugging Face)
HOST=0.0.0.0
